{
  "name": "evo-email-mcp",
  "version": "1.0.0",
  "description": "Multi-provider email MCP server for Claude",
  "repository": {
    "type": "git",
    "url": "https://github.com/lb603487485/evo-email-mcp.git"
  },
  "keywords": ["mcp", "email", "gmail", "outlook", "claude"],
  "main": "dist/server.js",
  "bin": {
    "evo-email-mcp": "dist/server.js",
    "evo-email-add-account": "dist/cli/add-account.js",
    "evo-email-remove-account": "dist/cli/remove-account.js"
  },
  "files": [
    "dist/",
    "config.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "add-account": "ts-node src/cli/add-account.ts",
    "remove-account": "ts-node src/cli/remove-account.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke-test": "ts-node src/cli/smoke-test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@inquirer/prompts": "^5.0.0",
    "commander": "^12.0.0",
    "googleapis": "^140.0.0",
    "keytar": "^7.9.0",
    "open": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
